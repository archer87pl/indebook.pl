# Baza danych — Supabase Postgres
# DATABASE_URL: połączenie przez pulę (pgbouncer, port 6543) — używane w runtime.
#   Skopiuj z Supabase → Project Settings → Database → Connection string → "Transaction"
#   i dopisz na końcu: ?pgbouncer=true&connection_limit=1
# DIRECT_URL: połączenie bezpośrednie (port 5432) — używane przez `prisma db push`.
DATABASE_URL="postgresql://postgres.xxxx:HASLO@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxx:HASLO@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Publiczny adres aplikacji (linki w e-mailach, powroty z płatności, iCal)
# produkcja: APP_URL="https://twojadomena.pl" (na Vercel zwykle URL projektu)
APP_URL="http://localhost:3001"

# Vercel Blob — storage zdjęć wgrywanych przez użytkowników.
# W dashboardzie Vercel: Storage → Create → Blob; token wstrzyknie się automatycznie
# w deploymencie. Do dev pobierz przez `vercel env pull`.
BLOB_READ_WRITE_TOKEN=""

# Sekret dla Vercel Cron (app/api/cron/*) — chroni endpointy zadań w tle.
# Ustaw dowolny losowy ciąg w zmiennych środowiskowych na Vercel.
CRON_SECRET=""

# E-maile przez Resend (https://resend.com) — puste = log do konsoli
RESEND_API_KEY=""
EMAIL_FROM="Rezio <onboarding@resend.dev>"

# SMS-y przez SMSAPI (https://www.smsapi.pl) — puste = log do konsoli.
# SMS_FROM: zarejestrowane pole nadawcy w SMSAPI; puste = "ECO" (SMS ekonomiczny
# z losowego numeru — działa bez rejestracji nadpisu, taniej).
SMSAPI_TOKEN=""
SMS_FROM=""

# Przelewy24: brak zmiennych — każdy obiekt podpina własne konto P24
# w panelu (/admin/platnosci/konfiguracja); bez danych działa symulacja.

# Strony WWW obiektów (moduł "Strona WWW" w panelu).
# SITES_BASE_DOMAIN: domena bazowa subdomen stron, np. willa.rezop.pl.
#   Wildcard *.rezop.pl musi wskazywać na projekt (na Vercel: dodaj domenę
#   *.rezop.pl do projektu). Lokalnie działa nazwa.localhost bez konfiguracji.
# WAŻNE: APP_URL musi wskazywać produkcyjną domenę aplikacji — proxy hostów
#   rozpoznaje po nim "swoją" domenę. Dodatkowe domeny aplikacji (np. stara)
#   można dopisać w APP_HOSTS (rozdzielone przecinkami). Hosty *.vercel.app
#   i nieznane domeny zawsze przechodzą do aplikacji (nigdy 404 z proxy).
SITES_BASE_DOMAIN="rezop.pl"
APP_HOSTS=""

# Podpinanie własnych domen klientów (plan Pro) przez Vercel API.
# VERCEL_TOKEN: Account Settings → Tokens; VERCEL_PROJECT_ID: Project Settings.
# VERCEL_TEAM_ID tylko dla projektów w teamie. Puste = sekcja domen ukryta.
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""
