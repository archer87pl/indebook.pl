generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // pula połączeń (pgbouncer) — używana przez aplikację w runtime na Vercel
  url       = env("DATABASE_URL")
  // bezpośrednie połączenie — używane przez `prisma db push` / migracje
  directUrl = env("DIRECT_URL")
}

// Konfiguracja platformy (bramki płatności, e-mail, SMS) edytowana z panelu
// superadmina. Wartość z bazy ma pierwszeństwo nad zmienną środowiskową
// o tym samym kluczu (ENV zostaje fallbackiem dla wdrożeń bez panelu).
model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Dziennik zdarzeń platformy: rezerwacje, płatności, wysyłki e-mail/SMS,
// synchronizacje iCal, akcje administratora, nieudane logowania.
// Retencja: wpisy starsze niż 90 dni kasuje cron (lib/jobs.ts).
model EventLog {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  level      String   @default("INFO") // INFO | WARN | ERROR
  kind       String // RESERVATION | PAYMENT | MAIL | SMS | ICAL | ADMIN | AUTH
  message    String
  propertyId Int? // kontekst obiektu (bez relacji — log przeżywa usunięcie obiektu)
  meta       String   @default("") // dodatkowy kontekst (np. kod rezerwacji, e-mail)

  @@index([createdAt])
  @@index([kind, createdAt])
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  name         String
  isAdmin      Boolean   @default(false) // globalny administrator platformy
  createdAt    DateTime             @default(now())
  sessions     Session[]
  resetTokens  PasswordResetToken[]
  property     Property?
}

model Session {
  token     String   @id
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt]) // retencja: cron kasuje wygasłe sesje
}

model PasswordResetToken {
  token     String   @id
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
}

model Property {
  id             Int        @id @default(autoincrement())
  ownerId        Int        @unique
  owner          User       @relation(fields: [ownerId], references: [id])
  slug           String     @unique
  name           String
  plan           String     @default("FREE") // FREE | STANDARD | PRO
  // zawieszony przez administratora platformy: ukryty w katalogu,
  // strona obiektu niedostępna, brak nowych rezerwacji
  suspended      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  description    String     @default("")
  address        String     @default("")
  checkInFrom    String     @default("15:00")
  checkOutTo     String     @default("11:00")
  depositPercent Int        @default(30)
  terms          String     @default("") // regulamin obiektu
  privacyPolicy  String     @default("") // polityka prywatności
  // dane sprzedawcy na fakturach (puste name/address = nazwa/adres obiektu)
  sellerName     String     @default("")
  sellerNip      String     @default("")
  sellerAddress  String     @default("")
  bankAccount    String     @default("")
  // instrukcje przyjazdu (kody drzwi, WiFi, dojazd) — gość widzi je dopiero
  // po wypełnieniu meldunku online (zachęta do potwierdzenia tożsamości)
  arrivalInfo    String     @default("")
  // Przelewy24 obiektu — zaliczki gości trafiają bezpośrednio na konto
  // właściciela (własna umowa z P24). Brak kompletu danych = tryb symulacji.
  p24MerchantId  String     @default("")
  p24PosId       String     @default("")
  p24ApiKey      String     @default("")
  p24Crc         String     @default("")
  p24Sandbox     Boolean    @default(true)
  unitTypes      UnitType[]
  photos         Photo[]
  promoCodes     PromoCode[]
  faqs           PropertyFaq[]
  pricingRules   PricingRule[]
  reviews        Review[]
  invoices       Invoice[]
  site           Site?
}

// Rate-limiter oknem stałym (login, reset hasła, formularz kontaktowy,
// akcje gościa po kodzie). Klucz = "akcja:identyfikator" (zwykle IP).
model RateLimit {
  key     String   @id
  count   Int
  resetAt DateTime

  @@index([resetAt]) // retencja: cron kasuje wygasłe okna
}

// Strona WWW obiektu budowana w kreatorze (moduł „Strona WWW" w panelu).
// draftConfig — wersja robocza edytowana w panelu; publishedConfig — to, co
// widzi świat (null = jeszcze nie opublikowana). Publikacja kopiuje draft →
// published, „cofnij zmiany" kopiuje published → draft.
model Site {
  id              Int       @id @default(autoincrement())
  propertyId      Int       @unique
  property        Property  @relation(fields: [propertyId], references: [id])
  // adres nazwa.<SITES_BASE_DOMAIN>, np. przystanek-lesna.rezop.pl
  subdomain       String    @unique
  // własna domena klienta (plan PRO), np. mojobiekt.pl
  customDomain    String?   @unique
  // NONE | PENDING | VERIFIED | ERROR
  domainStatus    String    @default("NONE")
  // szablon startowy: gorski | nadmorski | miejski | uniwersalny
  template        String    @default("uniwersalny")
  draftConfig     Json
  publishedConfig Json?
  customCss       String    @default("")
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Reguła cen dynamicznych — maks. jedna danego rodzaju na obiekt.
// Korekty per noc sumują się i nakładają na cenę z cennika (baza/sezon).
model PricingRule {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
  kind       String // WEEKEND | LAST_MINUTE | OCCUPANCY
  param      Int      @default(0) // LAST_MINUTE: dni do nocy (<=), OCCUPANCY: próg obłożenia %, WEEKEND: nieużywany
  percent    Int // korekta ceny nocy w %: dodatnia = podwyżka, ujemna = rabat
  active     Boolean  @default(true)

  @@unique([propertyId, kind])
}

model PropertyFaq {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
  question   String
  answer     String
  sort       Int      @default(0)

  @@index([propertyId])
}

model PromoCode {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
  code       String // wpisywany przez gościa, per obiekt
  percentOff Int // rabat % od kwoty pobytu
  validFrom  String   @default("") // YYYY-MM-DD lub puste = od zawsze
  validTo    String   @default("") // YYYY-MM-DD lub puste = bezterminowo
  maxUses    Int      @default(0) // 0 = bez limitu
  usedCount  Int      @default(0)
  active     Boolean  @default(true)

  @@unique([propertyId, code])
}

model Photo {
  id         Int       @id @default(autoincrement())
  propertyId Int?
  property   Property? @relation(fields: [propertyId], references: [id])
  unitTypeId Int?
  unitType   UnitType? @relation(fields: [unitTypeId], references: [id])
  path       String // ścieżka względem /public, np. /uploads/p1/abc.jpg
  createdAt  DateTime  @default(now())

  @@index([propertyId])
  @@index([unitTypeId])
}

model UnitType {
  id          Int          @id @default(autoincrement())
  propertyId  Int
  property    Property     @relation(fields: [propertyId], references: [id])
  name        String
  description String       @default("")
  maxGuests   Int
  basePriceGr Int
  minStay     Int          @default(1)
  amenities   String       @default("[]") // JSON: lista kluczy z lib/amenities.ts
  units       Unit[]
  seasons     RateSeason[]
  photos      Photo[]

  @@index([propertyId])
}

model Unit {
  id           Int           @id @default(autoincrement())
  unitTypeId   Int
  unitType     UnitType      @relation(fields: [unitTypeId], references: [id])
  name         String
  active       Boolean       @default(true) // false = wyłączona ze sprzedaży
  icalToken    String? // sekret w URL eksportu iCal
  reservations Reservation[]
  blocks       Block[]
  icalFeeds    IcalFeed[]

  @@index([unitTypeId])
}

// Zewnętrzny kalendarz (np. eksport iCal z Booking.com/Airbnb) — zajęte
// terminy lądują jako Block z source=ICAL przy każdej synchronizacji.
model IcalFeed {
  id         Int       @id @default(autoincrement())
  unitId     Int
  unit       Unit      @relation(fields: [unitId], references: [id])
  url        String
  name       String    @default("")
  channel    String    @default("OTHER") // BOOKING | AIRBNB | VRBO | OTHER
  lastSyncAt DateTime?
  lastError  String    @default("")
  blocks     Block[]

  @@index([unitId])
}

model RateSeason {
  id         Int      @id @default(autoincrement())
  unitTypeId Int
  unitType   UnitType @relation(fields: [unitTypeId], references: [id])
  name       String
  startDate  String // YYYY-MM-DD, pierwsza noc sezonu (inclusive)
  endDate    String // YYYY-MM-DD, ostatnia noc sezonu (inclusive)
  priceGr    Int
  minStay    Int      @default(1)

  @@index([unitTypeId])
}

model Block {
  id        Int       @id @default(autoincrement())
  unitId    Int
  unit      Unit      @relation(fields: [unitId], references: [id])
  startDate String // pierwsza zablokowana noc
  endDate   String // exclusive — jak checkOut
  note      String    @default("")
  source    String    @default("MANUAL") // MANUAL | ICAL
  feedId    Int?
  feed      IcalFeed? @relation(fields: [feedId], references: [id])

  @@index([unitId, startDate, endDate]) // dostępność i kalendarz obłożenia
  @@index([feedId]) // delete+recreate przy synchronizacji iCal
}

model Reservation {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  unitId    Int
  unit      Unit      @relation(fields: [unitId], references: [id])
  checkIn   String // YYYY-MM-DD
  checkOut  String // YYYY-MM-DD
  guests    Int
  guestName String
  email     String
  phone     String    @default("")
  nip       String    @default("") // NIP do faktury (opcjonalny)
  notes     String    @default("")
  totalGr    Int
  discountGr Int    @default(0) // udzielony rabat (kod promocyjny)
  promoCode  String @default("") // użyty kod
  depositGr  Int
  status         String    @default("PENDING") // PENDING | CONFIRMED | CANCELLED
  source         String    @default("ONLINE") // ONLINE | MANUAL
  paymentOrderId String    @default("") // orderId z bramki (P24) po opłaceniu
  createdAt      DateTime  @default(now())
  expiresAt      DateTime? // PENDING po tym czasie nie blokuje dostępności
  checkInStatus  String    @default("NONE") // NONE | COMPLETED — meldunek online
  // ustawiane przy wypełnieniu meldunku: link szedł na ten e-mail, więc adres jest żywy
  emailVerifiedAt   DateTime?
  // przypomnienie o jutrzejszym przyjeździe (e-mail/SMS) — wysłane raz, przez cron
  arrivalReminderAt DateTime?
  // prośba o opinię po pobycie (e-mail/SMS) — wysłana raz, przez cron
  reviewRequestedAt DateTime?
  checkInCard     CheckInCard?
  messages        Message[]
  review          Review?
  invoices        Invoice[]

  @@index([unitId, checkIn, checkOut]) // dostępność, kalendarz, plan dnia
  @@index([status, expiresAt]) // wygaszanie PENDING, filtry statusów
  @@index([createdAt]) // listy i eksport (orderBy desc)
}

// Faktura wystawiona z rezerwacji. Dane sprzedawcy i nabywcy są zapisane
// jako snapshot (niezmienne po wystawieniu). Kwoty w groszach.
model Invoice {
  id            Int          @id @default(autoincrement())
  propertyId    Int
  property      Property     @relation(fields: [propertyId], references: [id])
  reservationId Int?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  kind          String // PROFORMA | ZALICZKOWA | KONCOWA
  number        String // pełny numer, np. "FV 3/2026"
  seq           Int // kolejny numer w obrębie typ+rok+obiekt
  year          Int
  issueDate     String // YYYY-MM-DD (data wystawienia)
  saleDate      String // YYYY-MM-DD (data sprzedaży/usługi)
  sellerName    String
  sellerNip     String
  sellerAddress String
  bankAccount   String       @default("")
  buyerName     String
  buyerNip      String       @default("")
  buyerAddress  String       @default("")
  itemName      String // opis pozycji (usługa noclegowa …)
  grossGr       Int
  netGr         Int
  vatGr         Int
  vatRate       Int // stawka VAT w % (np. 8)
  createdAt     DateTime     @default(now())

  @@unique([propertyId, kind, year, seq])
  @@index([reservationId])
}

// Opinia gościa po pobycie — jedna na rezerwację. propertyId zdenormalizowany
// dla szybkich list i średniej per obiekt. Nie kasujemy — moderacja przez `hidden`.
model Review {
  id            Int         @id @default(autoincrement())
  reservationId Int         @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  propertyId    Int
  property      Property    @relation(fields: [propertyId], references: [id])
  authorName    String // wyświetlane skrócone (imię + inicjał), z guestName
  rating        Int // 1..5
  comment       String      @default("")
  ownerReply    String      @default("") // publiczna odpowiedź obiektu
  hidden        Boolean     @default(false) // moderacja: ukryj nadużycie
  createdAt     DateTime    @default(now())

  @@index([propertyId, hidden]) // listy opinii per obiekt (bez ukrytych)
}

// Wiadomość w czacie gość <-> obiekt przypiętym do rezerwacji.
model Message {
  id            Int         @id @default(autoincrement())
  reservationId Int
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  sender        String // GUEST | OWNER
  body          String
  createdAt     DateTime    @default(now())
  readAt        DateTime? // kiedy przeczytała druga strona (nieprzeczytane = null)

  @@index([reservationId, readAt]) // wątek czatu + badge nieprzeczytanych
}

// Karta meldunkowa (meldunek online) — dane osobowe gościa + e-podpis.
// PII: kasowane po okresie retencji (lib/jobs.ts purgeExpiredCheckIns);
// badge na rezerwacji (checkInStatus) zostaje jako informacja historyczna.
model CheckInCard {
  id            Int         @id @default(autoincrement())
  reservationId Int         @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  fullName      String
  address       String // adres zamieszkania
  citizenship   String      @default("polskie")
  docType       String      @default("") // DOWOD | PASZPORT | INNY | "" = nie podano
  docNumber     String      @default("") // tylko numer — bez skanów dokumentów (RODO)
  carPlate      String      @default("")
  arrivalTime   String      @default("") // HH:MM
  guestsJson    String      @default("[]") // dodatkowi goście: [{name, birthDate}]
  signaturePng  String // data:image/png;base64,... (~5–30 KB)
  termsAccepted Boolean     @default(false)
  rodoAccepted  Boolean     @default(false)
  completedAt   DateTime    @default(now())
}
